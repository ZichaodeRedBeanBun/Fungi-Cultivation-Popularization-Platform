<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.edu.seig.MhWeb.mapper.MushroomMapper">

    <select id="selectByMushroomName" resultType="cn.edu.seig.MhWeb.model.entity.MushroomInfo">
        select * from mh_mushroom_info
        where mushroom_name = #{mushroomName}
    </select>
</mapper>

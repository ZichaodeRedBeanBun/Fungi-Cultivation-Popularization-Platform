# 应用标题
VITE_APP_TITLE=MhWeb-Admin

# 后端 API 地址（请替换为你的实际后端服务地址）
VITE_APP_BASE_API=http://localhost:8080

# 开发服务器端口
VITE_PORT=5173

# 路由历史模式（hash 或 html5）
VITE_ROUTER_HISTORY=hash

# 生产环境是否移除 console
VITE_DROP_CONSOLE=true

# 公共路径
VITE_PUBLIC_PATH=/

# 是否启用 CDN
VITE_CDN=false

# 是否启用压缩
VITE_COMPRESSION=true
